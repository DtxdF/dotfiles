"Mis cosas

set number
set ignorecase
set hlsearch
set autowrite
set sw=4
set confirm
set tabstop=4
set cursorline
set autoindent
set ruler
set title
set term=xterm-256color
map <F8> :tabp<Enter>
map <F9> :tabn<Enter>
map - :qall<Enter>
map _ :wqall<Enter>
